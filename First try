def detect_tracker_loss(eye_df):
    """
    Identify samples where the eye-tracker has lost the gaze signal.
    Typically happens during blinks or when the headset slips
    
    Detection strategy:
        1. Any sample where GAZE_DIR_X, Y, Z are all exactly 0.0
