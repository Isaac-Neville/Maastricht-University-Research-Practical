def conv_time(time_float):      

    hours_float = float(time_float)     # including flaot from calculations in function
    total_seconds = hours_float * 3600      # convert hours into seconds (still float)
    seconds_int = int(total_seconds)        # convert float into integer

    hours = seconds_int // 3600     # calc amount of hrs
    r_m = seconds_int - (hours * 3600)      # calc remaining seconds after subtraction of hours
    minutes = r_m // 60     # calc amount of minutes
    seconds =  r_m - (minutes * 60)     # calc amount of seconds
    
    print(hours,":",minutes,":",seconds)        # giving output in hh:mm:ss format



