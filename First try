def detect_teleportation(eye_df):
    """
    Identify samples around teleportation events, which create artificial velocity spikes in the gaze data.

    Detection strategy:
        1. Compute the Euclidean distance between consecutive CAM_POS samples
        2. Flag any sample where this distance exceeds the TELEPORT_THRESHOLD_M as a teleportation event
